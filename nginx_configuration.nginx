# =======================================================================
# NGINX HIGH-PERFORMANCE MASTER REFACTOR ENGINE CONFLICT RESOLVED
# =======================================================================

# 1. Redirect all HTTP traffic to the canonical HTTPS WWW domain.
server {
    listen 80;
    server_name nailsmakingmachine.com www.nailsmakingmachine.com;
    return 301 https://www.nailsmakingmachine.com$request_uri;
}

# 2. Redirect HTTPS non-WWW traffic to the canonical domain.
server {
    listen 443 ssl http2;
    server_name nailsmakingmachine.com;
    
    # Configure your SSL certificate paths here.
    # ssl_certificate /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;
    
    return 301 https://www.nailsmakingmachine.com$request_uri;
}

# 3. Main high-performance website deployment block.
server {
    listen 443 ssl http2;
    server_name www.nailsmakingmachine.com;

    # Configure your SSL certificate paths here.
    # ssl_certificate /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    root /var/www/nailsmakingmachine; # Change to your actual website directory.
    index index.html;

    # Master Trust, Privacy & Security Headers Matrix (Locks down 100/100 Security Audits)
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Cross-Origin-Opener-Policy "same-origin" always;
    add_header Content-Security-Policy "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: https://www.nailsmakingmachine.com; child-src https://www.youtube.com https://www.google.com;" always;

    # Return the custom page while preserving a real HTTP 404 status.
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    # CRITICAL MULTI-PAGE REDIRECTION FIX: 
    # Tries to serve the physical asset file first. If it's a virtual path 
    # (like /about or /products), it falls back to index.html so the JS routing takes over.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Ultra-Efficient Gzip Compression Pipeline (Eliminates Network Payload Bloat)
    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_proxied expired no-cache no-store private auth;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # Long-lived Caching Layer for Versioned Static Assets (Resolves Cache Lifetime Audits)
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|webp|woff2|xml|kml|webmanifest)$ {
        expires 365d;
        add_header Cache-Control "public, max-age=31536000, no-transform, immutable";
        access_log off;
    }
}
