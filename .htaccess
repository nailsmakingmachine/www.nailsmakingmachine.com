RewriteEngine On
RewriteBase /

# Redirect query parameter internal routes to clean URLs
RewriteCond %{QUERY_STRING} ^p=([^&]+)$
RewriteRule ^$ /%1? [R=301,L]

# If the file or directory does not exist physically, process through index.html parameters
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)$ /?p=$1 [L,QSA]
