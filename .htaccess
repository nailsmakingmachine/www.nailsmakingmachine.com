RewriteEngine On
RewriteBase /

# 1. Prevent infinite loops: Only redirect if the request is actually for index.html with the parameter
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /\?p=([^\s&]+) [NC]
RewriteRule ^$ /%1? [R=301,L]

# 2. Exclude existing files, directories, and common assets so images/scripts don't break
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(javascript|css|webp|png|jpg|jpeg|gif|ico|svg|pdf)$ [NC]
RewriteRule ^([^/]+)$ index.html?p=$1 [L,QSA]
